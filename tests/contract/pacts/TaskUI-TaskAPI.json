{
  "consumer": {
    "name": "TaskUI"
  },
  "interactions": [
    {
      "description": "a login request with valid credentials",
      "pending": false,
      "providerStates": [
        {
          "name": "a registered user exists"
        }
      ],
      "request": {
        "body": {
          "content": {
            "password": "password",
            "username": "testuser"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "method": "POST",
        "path": "/api/auth/login"
      },
      "response": {
        "body": {
          "content": {
            "token": "eyJ"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    },
    {
      "description": "an authenticated request to create a task",
      "pending": false,
      "providerStates": [
        {
          "name": "user is authenticated"
        }
      ],
      "request": {
        "body": {
          "content": {
            "title": "New task"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Authorization": [
            "Bearer token"
          ],
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/tasks"
      },
      "response": {
        "body": {
          "content": {
            "completed": false,
            "id": 1,
            "title": "New task",
            "username": "testuser"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.completed": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.username": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      },
      "type": "Synchronous/HTTP"
    },
    {
      "description": "an authenticated request to list tasks",
      "pending": false,
      "providerStates": [
        {
          "name": "user has tasks"
        }
      ],
      "request": {
        "headers": {
          "Authorization": [
            "Bearer token"
          ]
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/api/tasks"
      },
      "response": {
        "body": {
          "content": [
            {
              "completed": false,
              "id": 1,
              "title": "Buy groceries",
              "username": "testuser"
            }
          ],
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].completed": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].username": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "TaskAPI"
  }
}